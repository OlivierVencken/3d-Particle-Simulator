#version 430 core

layout(local_size_x = 256) in;

#define MAX_GROUPS 16
#define DISTANCE_EUCLIDEAN 0
#define DISTANCE_MANHATTAN 1
#define DISTANCE_CHEBYSHEV 2

layout(std430, binding = 0) readonly buffer Positions {
    vec4 positions[];
};

layout(std430, binding = 1) readonly buffer Velocities {
    vec4 velocities[];
};

layout(std430, binding = 2) readonly buffer GridParticleIds {
    int particle_ids[];
};

layout(std430, binding = 3) readonly buffer GridCounts {
    int grid_counts[];
};

layout(std430, binding = 4) readonly buffer GridOffsets {
    int grid_offsets[];
};

layout(std430, binding = 6) writeonly buffer NextPositions {
    vec4 next_positions[];
};

layout(std430, binding = 7) writeonly buffer NextVelocities {
    vec4 next_velocities[];
};

uniform float uDeltaTime;
uniform int uParticleCount;
uniform int uGroupCount;
uniform float uForceFactor;
uniform float uVelocityDamping;
uniform float uInteractionRange;
uniform float uRepulsionRadius;
uniform float uMaxVelocity;
uniform float uBoundaryBounce;
uniform float uBounds;
uniform int uDensityRegulationEnabled;
uniform float uDensityLimit;
uniform int uDistanceMetric;
uniform int uGridSize;
uniform int uToroidalWrap;
uniform float uAttractionMatrix[MAX_GROUPS * MAX_GROUPS];

float attraction(int groupI, int groupJ) {
    groupI = clamp(groupI, 0, uGroupCount - 1);
    groupJ = clamp(groupJ, 0, uGroupCount - 1);
    return uAttractionMatrix[groupI * MAX_GROUPS + groupJ];
}

ivec3 getGridCoord(vec3 position) {
    vec3 normalized = (position + vec3(uBounds)) / uInteractionRange;
    return clamp(ivec3(floor(normalized)), ivec3(0), ivec3(uGridSize - 1));
}

int getGridIndex(ivec3 coord) {
    return coord.x + uGridSize * (coord.y + uGridSize * coord.z);
}

float calculateForce(float normalizedDistance, float attractionValue, float repulsionRadius) {
    if (normalizedDistance < repulsionRadius) {
        return normalizedDistance / repulsionRadius - 1.0;
    }

    return attractionValue
        * (1.0 - abs(2.0 * normalizedDistance - 1.0 - repulsionRadius) / (1.0 - repulsionRadius));
}

vec3 toroidalDistance(vec3 from, vec3 to) {
    vec3 difference = to - from;
    float worldSize = uBounds * 2.0;
    return difference - worldSize * round(difference / worldSize);
}

float metricDistance(vec3 direction, float euclideanDistance) {
    vec3 absoluteDirection = abs(direction);
    if (uDistanceMetric == DISTANCE_MANHATTAN) {
        return absoluteDirection.x + absoluteDirection.y + absoluteDirection.z;
    }
    if (uDistanceMetric == DISTANCE_CHEBYSHEV) {
        return max(max(absoluteDirection.x, absoluteDirection.y), absoluteDirection.z);
    }
    return euclideanDistance;
}

ivec3 wrapGridCoord(ivec3 coord) {
    return ivec3(
        (coord.x + uGridSize) % uGridSize,
        (coord.y + uGridSize) % uGridSize,
        (coord.z + uGridSize) % uGridSize
    );
}

vec3 wrapPosition(vec3 position) {
    float worldSize = uBounds * 2.0;
    return mod(position + vec3(uBounds), vec3(worldSize)) - vec3(uBounds);
}

void main() {
    uint id = gl_GlobalInvocationID.x;
    if (id >= uint(uParticleCount)) {
        return;
    }

    vec4 packedPosition = positions[id];
    vec3 position = packedPosition.xyz;
    vec3 velocity = velocities[id].xyz;
    int groupI = int(packedPosition.w);
    vec3 force = vec3(0.0);
    vec3 positiveAttractionForce = vec3(0.0);
    ivec3 currentGrid = getGridCoord(position);

    float inverseInteractionRange = 1.0 / uInteractionRange;
    float repulsionRadius = clamp(uRepulsionRadius, 0.01, 0.95);
    float localDensity = 0.0;
    bool densityRegulated = uDensityRegulationEnabled == 1;
    float densityCap = uDensityLimit + 1.0;

    int minimumOffset = uGridSize <= 1 ? 0 : -1;
    int maximumOffset = uGridSize <= 1 ? 0 : (uGridSize == 2 && uToroidalWrap == 1 ? 0 : 1);

    for (int dz = minimumOffset; dz <= maximumOffset; dz++) {
        for (int dy = minimumOffset; dy <= maximumOffset; dy++) {
            for (int dx = minimumOffset; dx <= maximumOffset; dx++) {
                ivec3 neighborGrid = currentGrid + ivec3(dx, dy, dz);
                if (uToroidalWrap == 1) {
                    neighborGrid = wrapGridCoord(neighborGrid);
                } else if (any(lessThan(neighborGrid, ivec3(0)))
                        || any(greaterThanEqual(neighborGrid, ivec3(uGridSize)))) {
                    continue;
                }

                int neighborIndex = getGridIndex(neighborGrid);
                int firstParticle = grid_offsets[neighborIndex];
                int cellParticleCount = grid_counts[neighborIndex];

                for (int i = 0; i < cellParticleCount; i++) {
                    int otherId = particle_ids[firstParticle + i];
                    if (otherId == int(id)) {
                        continue;
                    }

                    vec4 otherPosition = positions[otherId];
                    vec3 direction = uToroidalWrap == 1
                        ? toroidalDistance(position, otherPosition.xyz)
                        : otherPosition.xyz - position;
                    float squaredEuclideanDistance = dot(direction, direction);
                    if (squaredEuclideanDistance <= 0.00000001) {
                        continue;
                    }

                    float inverseEuclideanDistance = inversesqrt(squaredEuclideanDistance);
                    float euclideanDistance = squaredEuclideanDistance * inverseEuclideanDistance;
                    float normalizedDistance = metricDistance(direction, euclideanDistance) * inverseInteractionRange;
                    if (normalizedDistance >= 1.0) {
                        continue;
                    }

                    int groupJ = int(otherPosition.w);
                    float attractionValue = attraction(groupI, groupJ);
                    if (densityRegulated && localDensity < densityCap) {
                        float densityWeight = 1.0 - normalizedDistance;
                        localDensity += groupI == groupJ ? densityWeight : densityWeight * 0.5;
                    }

                    float forceMagnitude = calculateForce(normalizedDistance, attractionValue, repulsionRadius);
                    vec3 forceContribution = direction * inverseEuclideanDistance * forceMagnitude * uForceFactor;
                    if (densityRegulated && attractionValue > 0.0 && normalizedDistance >= repulsionRadius) {
                        positiveAttractionForce += forceContribution;
                    } else {
                        force += forceContribution;
                    }
                }
            }
        }
    }

    if (densityRegulated) {
        float densityFactor = clamp(1.0 - max(0.0, localDensity - uDensityLimit), 0.0, 1.0);
        force += positiveAttractionForce * densityFactor;
    }

    velocity = (velocity + force * uDeltaTime * 0.1) * uVelocityDamping;
    float squaredVelocity = dot(velocity, velocity);
    float maximumSquaredVelocity = uMaxVelocity * uMaxVelocity;
    if (squaredVelocity > maximumSquaredVelocity) {
        velocity *= uMaxVelocity * inversesqrt(squaredVelocity);
    }

    position += velocity * uDeltaTime;
    if (uToroidalWrap == 1) {
        position = wrapPosition(position);
    } else {
        for (int axis = 0; axis < 3; axis++) {
            if (position[axis] > uBounds) {
                position[axis] = uBounds;
                velocity[axis] *= -uBoundaryBounce;
            } else if (position[axis] < -uBounds) {
                position[axis] = -uBounds;
                velocity[axis] *= -uBoundaryBounce;
            }
        }
    }

    next_positions[id] = vec4(position, packedPosition.w);
    next_velocities[id] = vec4(velocity, 0.0);
}
